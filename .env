# ================= SIGNAL (M15) =================
COOLDOWN_SEC_MAIN=900
STRUCTURE_LOOKBACK=20        # số nến M15 để xác định đỉnh/đáy cấu trúc
VOL_BREAKOUT_MIN=2.0         # volume breakout phải > 1.5x SMA20
